{
  "assistant_messages": {
    "tool_round_limit": "Tool limit reached."
  },
  "server_tools": [
    {
      "type": "openrouter:web_search",
      "feature": "web_search",
      "x-strappy-display": {
        "label": "Web Search",
        "promoted_path": [
          "action",
          "query"
        ]
      }
    },
    {
      "type": "openrouter:web_fetch",
      "feature": "web_search",
      "x-strappy-display": {
        "label": "Web Fetch",
        "promoted_path": [
          "url"
        ],
        "transform": "url"
      }
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "database_list_info",
        "description": "Call this tool to view available databases",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": [],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "database_query",
        "description": "ALWAYS query the relevant approved database before finalizing when the request depends on personal data. Do not guess the user's data.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": "string"
            },
            "sql": {
              "type": "string"
            }
          },
          "required": [
            "database_id",
            "sql"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_datetime_to_iso8601",
        "description": "ALWAYS call this tool when displaying numeric timestamps. Convert one or more numeric timestamps to ISO 8601 datetimes.",
        "parameters": {
          "type": "object",
          "properties": {
            "timestamps": {
              "type": "string"
            },
            "unit": {
              "type": "string",
              "enum": [
                "unix_seconds",
                "unix_milliseconds",
                "unix_microseconds",
                "unix_nanoseconds",
                "apple_seconds",
                "apple_milliseconds",
                "apple_microseconds",
                "apple_nanoseconds"
              ]
            }
          },
          "required": [
            "timestamps"
          ],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_datetime_from_iso8601",
        "description": "ALWAYS call this tool when converting ISO 8601 datetimes to numeric timestamps.",
        "parameters": {
          "type": "object",
          "properties": {
            "datetimes": {
              "type": "string"
            },
            "unit": {
              "type": "string",
              "enum": [
                "unix_seconds",
                "unix_milliseconds",
                "unix_microseconds",
                "unix_nanoseconds",
                "apple_seconds",
                "apple_milliseconds",
                "apple_microseconds",
                "apple_nanoseconds"
              ]
            }
          },
          "required": [
            "datetimes"
          ],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_fontawesome_shortcode_search",
        "description": "ALWAYS use Font Awesome version 7 Free tools and shortcodes for visual expression instead of Unicode emoji. Search for icon shortcodes and render icons in answers with [fa:icon-shortcode-name] Markdown syntax.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "query"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_fontawesome_shortcode_confirm",
        "description": "ALWAYS confirm that Font Awesome version 7 Free shortcodes exist before using them. Render confirmed icons in answers with [fa:icon-shortcode-name] Markdown syntax instead of Unicode emoji.",
        "parameters": {
          "type": "object",
          "properties": {
            "shortcodes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "maxItems": 32
            }
          },
          "required": [
            "shortcodes"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "shortcodes",
        "transform": "comma_separated"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_read",
        "description": "Call this tool to retrieve durable facts stored about the user.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "limit": {
              "type": "integer"
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "query"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_remember",
        "description": "ALWAYS call this tool to store durable facts learned from the user or their databases that will be useful to you in the future. NEVER store secrets or sensitive information.",
        "parameters": {
          "type": "object",
          "properties": {
            "fact": {
              "type": "string"
            }
          },
          "required": [
            "fact"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "fact"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_forget",
        "description": "Call this tool to forget durable facts that are no longer correct or useful.",
        "parameters": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "id",
        "transform": "identifier"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_session_name_write",
        "description": "ALWAYS give the session a short, descriptive name.",
        "parameters": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "name"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "database_context_read",
        "description": "ALWAYS call this tool before calling database_query to avoid making mistakes when reading databases.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": "string"
            },
            "query": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "limit": {
              "type": "integer"
            }
          },
          "required": [],
          "minProperties": 1,
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_database_hint_remember",
        "description": "ALWAYS call this tool to store durable information that will help you query a database in the future. NEVER store user data with this tool.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": "string"
            },
            "hint": {
              "type": "string"
            }
          },
          "required": [
            "database_id",
            "hint"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_database_hint_forget",
        "description": "Call this tool to forget information about databases that is no longer correct nor helpful.",
        "parameters": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "id",
        "transform": "database_hint_filename"
      }
    }
  ]
}
