{
  "assistant_messages": {
    "tool_round_limit": "Tool limit reached."
  },
  "server_tools": [
    {
      "type": "openrouter:web_search",
      "feature": "web_search",
      "x-strappy-display": {
        "label": "Web Search",
        "promoted_path": [
          "action",
          "query"
        ]
      }
    },
    {
      "type": "openrouter:web_fetch",
      "feature": "web_search",
      "x-strappy-display": {
        "label": "Web Fetch",
        "promoted_path": [
          "url"
        ],
        "transform": "url"
      }
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "database_list_info",
        "description": "Call this tool to view available databases",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": [],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "database_query",
        "description": "ALWAYS query the relevant approved database before finalizing when the request depends on personal data. Do not guess the user's data.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": "string"
            },
            "sql": {
              "type": "string"
            }
          },
          "required": [
            "database_id",
            "sql"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_datetime_to_iso8601",
        "description": "ALWAYS call this tool when displaying numeric timestamps. Convert one or more numeric timestamps to ISO 8601 datetimes.",
        "parameters": {
          "type": "object",
          "properties": {
            "timestamps": {
              "type": "string"
            },
            "unit": {
              "type": "string",
              "enum": [
                "unix_seconds",
                "unix_milliseconds",
                "unix_microseconds",
                "unix_nanoseconds",
                "apple_seconds",
                "apple_milliseconds",
                "apple_microseconds",
                "apple_nanoseconds"
              ]
            }
          },
          "required": [
            "timestamps"
          ],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_datetime_from_iso8601",
        "description": "ALWAYS call this tool when converting ISO 8601 datetimes to numeric timestamps.",
        "parameters": {
          "type": "object",
          "properties": {
            "datetimes": {
              "type": "string"
            },
            "unit": {
              "type": "string",
              "enum": [
                "unix_seconds",
                "unix_milliseconds",
                "unix_microseconds",
                "unix_nanoseconds",
                "apple_seconds",
                "apple_milliseconds",
                "apple_microseconds",
                "apple_nanoseconds"
              ]
            }
          },
          "required": [
            "datetimes"
          ],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_fontawesome_shortcode_search",
        "description": "ALWAYS use Font Awesome version 7 Free tools and shortcodes for visual expression instead of Unicode emoji. Search for icon shortcodes and render icons in answers with [fa:icon-shortcode-name] Markdown syntax.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "query"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_fontawesome_shortcode_confirm",
        "description": "ALWAYS call this tool before the final answer. Set shortcodes to a non-empty array of Font Awesome version 7 Free shortcodes to confirm before using them. Null and empty arrays are invalid. Render confirmed icons in answers with [fa:icon-shortcode-name] Markdown syntax. NEVER use unicode emoji.",
        "parameters": {
          "type": "object",
          "properties": {
            "shortcodes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "maxItems": 32
            }
          },
          "required": [
            "shortcodes"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "shortcodes",
        "transform": "comma_separated"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_read",
        "description": "Call this tool to retrieve durable facts stored about the user.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "limit": {
              "type": "integer"
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "query"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_remember",
        "description": "ALWAYS call this tool. Set fact to a useful durable user fact, or null if there is nothing new to remember. NEVER store secrets or sensitive information.",
        "parameters": {
          "type": "object",
          "properties": {
            "fact": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "fact"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_user_fact_forget",
        "description": "Call this tool to forget durable facts that are no longer correct or useful.",
        "parameters": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "id",
        "transform": "identifier"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "helper_session_name_write",
        "description": "ALWAYS call this tool before the final answer. Update the session with a short, descriptive name for the user's latest prompt. A non-empty name is required; null and empty values are invalid.",
        "parameters": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "name"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "database_context_read",
        "description": "ALWAYS call this tool before the final answer. Read relevant approved database context before calling database_query. Otherwise call with no arguments, null arguments, or empty strings to report that no database context was needed.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "query": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": [
                "string",
                "null"
              ]
            },
            "limit": {
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_database_hint_remember",
        "description": "ALWAYS call this tool. Set database_id to the approved database ID and hint to useful durable query, schema, or access information, or set both to null if there is nothing new to remember. NEVER store user data, secrets, sensitive information, guesses, or one-off query results.",
        "parameters": {
          "type": "object",
          "properties": {
            "database_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "hint": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "database_id",
        "transform": "database_filename"
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_database_hint_forget",
        "description": "Call this tool to forget information about databases that is no longer correct nor helpful.",
        "parameters": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      },
      "x-strappy-display": {
        "promoted_argument": "id",
        "transform": "database_hint_filename"
      }
    }
  ]
}
